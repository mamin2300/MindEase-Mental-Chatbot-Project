@* GenerateReport.cshtml *@
@* Author: Malika *@
@* Form for generating a new mental health report *@

@model MindEase_Mental_Chatbot_Project.Models.MentalHealthReport

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Generate Report";
    ViewData["Page"] = "GenerateReport";
}

<div class="container mt-4">
    <h2>Generate Mental Health Report</h2>

    @* Form posts to AnalyticsController GenerateReport POST action *@
    <form asp-action="GenerateReport" method="post">

        @* Report title input *@
        <div class="mb-3">
            <label asp-for="Title" class="form-label">Report Title</label>
            <input asp-for="Title" class="form-control" placeholder="Enter report title" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        @* Report type dropdown *@
        <div class="mb-3">
            <label asp-for="ReportType" class="form-label">Report Type</label>
            <select asp-for="ReportType" class="form-control">
                <option value="">Select type</option>
                <option value="Monthly">Monthly</option>
                <option value="Weekly">Weekly</option>
                <option value="Custom">Custom</option>
            </select>
        </div>

        @* Time period input *@
        <div class="mb-3">
            <label asp-for="TimePeriod" class="form-label">Time Period</label>
            <input asp-for="TimePeriod" class="form-control" placeholder="e.g. January 2025" />
        </div>

        @* Generated by input *@
        <div class="mb-3">
            <label asp-for="GeneratedBy" class="form-label">Generated By</label>
            <input asp-for="GeneratedBy" class="form-control" placeholder="Enter your name" />
        </div>

        @* Data notes textarea *@
        <div class="mb-3">
            <label asp-for="DataSnapshot" class="form-label">Data Notes</label>
            <textarea asp-for="DataSnapshot" class="form-control" rows="4"
                      placeholder="Enter any notes about this report"></textarea>
        </div>

        @* Submit and cancel buttons *@
        <button type="submit" class="btn btn-primary">Generate Report</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>