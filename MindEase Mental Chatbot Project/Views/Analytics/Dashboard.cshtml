@* Dashboard.cshtml *@
@* Author: Malika *@
@* Displays summary metrics for the campus wellness administrator *@

@model Dictionary<string, double>


@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Analytics Dashboard";
    ViewData["Page"] = "Dashboard";
}

<div class="container mt-4">
    <h2>Campus Wellness Dashboard</h2>
    <p class="text-muted">Summary of mental health metrics across campus</p>

    <div class="row mt-4">
        <div class="col-md-3">
            <div class="card mb-3" style="background-color: #b8d4e8; border: none;">
                <div class="card-header" style="background-color: #a0c4de; border: none;">Total Reports</div>
                <div class="card-body">
                    <h3 class="card-title">@Model["TotalReports"]</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card mb-3" style="background-color: #b8e8c8; border: none;">
                <div class="card-header" style="background-color: #a0deb4; border: none;">Active Users</div>
                <div class="card-body">
                    <h3 class="card-title">@Model["ActiveUsers"]</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card mb-3" style="background-color: #f5e6c8; border: none;">
                <div class="card-header" style="background-color: #f0dab0; border: none;">Mood Entries</div>
                <div class="card-body">
                    <h3 class="card-title">@Model["MoodEntries"]</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card mb-3" style="background-color: #c8e0f0; border: none;">
                <div class="card-header" style="background-color: #b0d0e8; border: none;">Chat Sessions</div>
                <div class="card-body">
                    <h3 class="card-title">@Model["ChatSessions"]</h3>
                </div>
            </div>
        </div>
    </div>

    <a asp-action="Index" class="btn btn-secondary mt-3">View All Reports</a>
</div>