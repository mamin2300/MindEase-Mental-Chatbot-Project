@* ViewReport.cshtml *@
@* Author: Malika *@
@* Displays the details of a single generated mental health report *@

@model MindEase_Mental_Chatbot_Project.Models.MentalHealthReport

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "View Report";
    ViewData["Page"] = "Reports";
}

<div class="container mt-4">

    @* Page heading *@
    <h2>Mental Health Report</h2>

    @* Report details card *@
    <div class="card mt-3">
        <div class="card-header">
            @* Report title from model *@
            <h4>@Model.Title</h4>
        </div>
        <div class="card-body">

            @* Display each report field *@
            <p><strong>Report Type:</strong> @Model.ReportType</p>
            <p><strong>Time Period:</strong> @Model.TimePeriod</p>
            <p><strong>Generated By:</strong> @Model.GeneratedBy</p>
            <p><strong>Generated Date:</strong> @Model.GeneratedDate.ToShortDateString()</p>

            <hr />

            @* Data snapshot section - contains admin notes about the report *@
            <h5>Data Notes</h5>
            <p>@Model.DataSnapshot</p>
        </div>
    </div>

    @* Navigation back to reports list *@
    <a asp-action="Index" class="btn btn-secondary mt-3">Back to Reports</a>
</div>