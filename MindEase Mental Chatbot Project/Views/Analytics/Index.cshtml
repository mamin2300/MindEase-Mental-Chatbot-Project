@* Author: Malika *@
@* Displays a list of all generated mental health reports *@

@model List<MindEase_Mental_Chatbot_Project.Models.MentalHealthReport>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Analytics - All Reports";
    ViewData["Page"] = "Reports";
}

<div class="container mt-4">
    <h2>Mental Health Reports</h2>
    <a asp-action="GenerateReport" class="btn btn-primary mb-3">Generate New Report</a>
    <a asp-action="Dashboard" class="btn btn-secondary mb-3">View Dashboard</a>

    @if (Model.Count == 0)
    {
        <p>No reports generated yet.</p>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Time Period</th>
                    <th>Generated By</th>
                    <th>Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var report in Model)
                {
                    <tr>
                        <td>@report.Title</td>
                        <td>@report.ReportType</td>
                        <td>@report.TimePeriod</td>
                        <td>@report.GeneratedBy</td>
                        <td>@report.GeneratedDate.ToShortDateString()</td>
                        <td>
                            <a asp-action="ViewReport" asp-route-id="@report.Id"
                               class="btn btn-sm btn-info">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>