@model List<MindEase_Mental_Chatbot_Project.Models.MoodEntry>

@{
    ViewData["Title"] = "Dashboard";
    ViewData["Page"] = "Dashboard";
    Layout = "_StudentLayout";

    var avg = ViewBag.MoodAverage as double?;
    string greetingMessage;
    string greetingColor;

    if (avg == null)
    {
        greetingMessage = "Let's help you stay on top of your wellness today.";
        greetingColor = "text-muted";
    }
    else if (avg >= 4)
    {
        greetingMessage = "You've been in great spirits this week! Keep it up.";
        greetingColor = "text-success";
    }
    else if (avg >= 3)
    {
        greetingMessage = "You've been doing okay this week. Small steps make a big difference.";
        greetingColor = "text-primary";
    }
    else
    {
        greetingMessage = "It looks like you've had a tough week. Remember, support is always here for you.";
        greetingColor = "text-danger";
    }
}

<!-- Welcome header -->
<div class="dash-header mb-4">
    <h2 class="dash-welcome">Hi, @(User.Identity?.Name ?? "Student")</h2>
    <p class="dash-sub @greetingColor">@greetingMessage</p>
</div>

<!-- Feature cards -->
<div class="row g-3 mb-5">
    <div class="col-md-4">
        <div class="dash-card">
            <div class="dash-card-icon">💬</div>
            <h5>Chat with MindEase</h5>
            <p>Talk to our AI chatbot about how you're feeling.</p>
            <a asp-action="Chat" asp-controller="Student" class="btn btn-primary btn-sm">Start Chat</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dash-card">
            <div class="dash-card-icon">📝</div>
            <h5>Log Your Mood</h5>
            <p>Track your daily mood and feelings.</p>
            <a asp-action="LogMood" asp-controller="Student" class="btn btn-primary btn-sm">Log Mood</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dash-card">
            <div class="dash-card-icon">🩺</div>
            <h5>Mental Health Triage</h5>
            <p>Get an assessment of your current mental health.</p>
            <a asp-action="Index" asp-controller="Triage" class="btn btn-primary btn-sm">Start Triage</a>
        </div>
    </div>
</div>

<!-- Mood chart -->
@if (ViewBag.ChartValues != null && ((List<int>)ViewBag.ChartValues).Count > 0)
{
    <div class="dash-section mb-5">
        <h4 class="dash-section-title">Your Mood This Week</h4>
        <canvas id="moodChart" height="80"></canvas>
    </div>
}

<!-- Mood history preview -->
<div class="dash-section">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="dash-section-title">Recent Mood History</h4>
        <a asp-action="MoodHistory" asp-controller="Student" class="btn btn-outline-primary btn-sm">
            View Full History
        </a>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row g-3">
            @foreach (var entry in Model)
            {
                <div class="col-md-4">
                    <div class="mood-preview-card">
                        <div class="mood-preview-date">@entry.CreatedAt.ToString("MMM d, yyyy")</div>
                        <div class="mood-preview-level">
                            @for (int i = 0; i < entry.MoodLevel; i++)
                            {
                                <span>★</span>
                            }
                            @for (int i = entry.MoodLevel; i < 5; i++)
                            {
                                <span class="empty-star">☆</span>
                            }
                        </div>
                        <div class="mood-preview-note">@(entry.Notes ?? "No notes")</div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No mood entries yet. <a asp-action="LogMood">Log your first mood.</a></p>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartLabels ?? new List<string>()));
        const values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartValues ?? new List<int>()));

        if (labels.length > 0) {
            const ctx = document.getElementById('moodChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Mood Level',
                        data: values,
                        borderColor: '#708090',
                        backgroundColor: 'rgba(112,128,144,0.15)',
                        borderWidth: 2,
                        pointBackgroundColor: '#4B3935',
                        tension: 0.3,
                        fill: true
                    }]
                },
                options: {
                    scales: {
                        y: { min: 1, max: 5, ticks: { stepSize: 1 } }
                    },
                    plugins: { legend: { display: false } }
                }
            });
        }
    </script>
}