@model List<MindEase_Mental_Chatbot_Project.Models.MoodEntry>

@{
    ViewData["Title"] = "Mood History";
}

<h2>Mood History</h2>
<p>Your past mood entries</p>

<a asp-action="LogMood" class="btn btn-success mb-3">Log New Mood</a>

@if (Model != null && Model.Count > 0)
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Mood Level</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var mood in Model)
            {
                <tr>
                    <td>@mood.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                    <td>
                        @for (int i = 0; i < mood.MoodLevel; i++)
                        {
                            <span>*</span>
                        }
                        (@mood.MoodLevel/5)
                    </td>
                    <td>@mood.Notes</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No mood entries yet.</p>
}
