@model MindEase_Mental_Chatbot_Project.Models.TriageResult

@{
    ViewData["Title"] = "Assessment Result";
    ViewData["Page"] = "Triage";
    Layout = "_StudentLayout";
}

<h2>Your Assessment Result</h2>
<p>Assessed on @Model.AssessedAt.ToString("MMMM d, yyyy 'at' h:mm tt")</p>

<div class="card p-4 mb-3" style="max-width: 600px;">
    <h5>Risk Level: <strong>@Model.RiskLevel</strong></h5>
    <p>@Model.AssessmentNotes</p>
</div>

<div class="card p-4 mb-3" style="max-width: 600px;">
    <h5>What You Shared</h5>
    <p><em>"@Model.StudentMessage"</em></p>
</div>

<a asp-action="Index" asp-controller="Triage" class="btn btn-secondary">New Assessment</a>
<a asp-action="Chat" asp-controller="Student" class="btn btn-primary">Open Chat</a>